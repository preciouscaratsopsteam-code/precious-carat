{% comment %}
  Product Card Snippet - Myntra-style compact card
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

<div class="product-card{% unless product.available %} product-card--sold-out{% endunless %}" id="product-card-{{ product.id }}" data-weight-carats="{{ product.metafields.custom.weight_carats | default: 0 }}" data-weight-ratti="{{ product.metafields.custom.weight_ratti | default: 0 }}">
  <div class="product-card__image-wrapper">
    <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title }}">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 420 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          loading="lazy"
          class="product-card__image"
        >
      {%- else -%}
        <div class="product-card__placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}
    </a>

    <div class="product-card__badges"></div>

    <div class="product-card__media-actions">
      <button
        class="product-card__action-btn product-card__quick-view"
        aria-label="Quick View"
        data-quick-view
        data-product-handle="{{ product.handle }}"
        data-gem-type="{{ product.metafields.custom.gem_type | default: product.type | escape }}"
        data-gem-origin="{{ product.metafields.custom.origin | escape }}"
        data-gem-weight-carats="{{ product.metafields.custom.weight_carats }}"
        data-gem-weight-ratti="{{ product.metafields.custom.weight_ratti }}"
        data-gem-shape-cut="{{ product.metafields.custom.shape_cut | escape }}"
        data-gem-cutting-style="{{ product.metafields.custom.cutting_style | escape }}"
        data-gem-transparency="{{ product.metafields.custom.transparency | escape }}"
        data-gem-color="{{ product.metafields.custom.color_description | escape }}"
        data-gem-planet="{{ product.metafields.custom.planetary_alignment | escape }}"
        data-gem-cert-lab="{{ product.metafields.custom.cert_lab | escape }}"
        data-gem-cert-number="{{ product.metafields.custom.cert_number | escape }}"
        data-gem-cert-link="{{ product.metafields.custom.cert_link | escape }}"
        data-gem-treatment="{{ product.metafields.custom.treatment_status | escape }}"
        data-gem-dimensions="{{ product.metafields.custom.dimensions | escape }}"
        data-gem-species="{{ product.metafields.custom.gems_title | escape }}"
      >
        {% render 'icon', name: 'eye' %}
      </button>

      {%- assign video_media = product.media | where: 'media_type', 'video' | first -%}
      {%- if video_media == nil -%}
        {%- assign video_media = product.media | where: 'media_type', 'external_video' | first -%}
      {%- endif -%}

      {%- if product.metafields.custom.video != blank -%}
        {%- assign card_vimeo_url = product.metafields.custom.video -%}
        {%- assign card_vimeo_id = card_vimeo_url | split: 'vimeo.com/' | last | split: '?' | first -%}
        <button
          class="product-card__action-btn product-card__play"
          aria-label="Play Video"
          data-video-play
          onclick="event.preventDefault(); event.stopPropagation(); openCardVideoPopup('{{ card_vimeo_id }}');"
        >
          {% render 'icon', name: 'play' %}
        </button>
      {%- elsif video_media -%}
        <button
          class="product-card__action-btn product-card__play"
          aria-label="Play Video"
          data-video-play
          onclick="event.preventDefault(); window.location.href='{{ product.url }}?media={{ video_media.id }}';"
        >
          {% render 'icon', name: 'play' %}
        </button>
      {%- endif -%}
    </div>

    <button
      class="product-card__compare"
      aria-label="Compare product"
      data-product-handle="{{ product.handle }}"
      data-product-title="{{ product.title | escape }}"
      data-product-url="{{ product.url }}"
      data-product-price="{{ product.price | money }}"
      data-product-image="{{ product.featured_image | image_url: width: 420 }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-product-available="{{ product.available }}"
      data-product-type="{{ product.type | escape }}"
      data-product-vendor="{{ product.vendor | escape }}"
      onclick="event.preventDefault(); event.stopPropagation(); CompareApp.toggle(this);"
    >
      <img src="{{ 'balance.svg' | asset_url }}" width="18" height="18">
    </button>
  </div>

  <div class="product-card__info">
    <a href="{{ product.url }}" class="product-card__title-link">
      <h3 class="product-card__title">{{ product.title | default: "Product Name" }}{%- unless product.available -%} <span class="product-card__sold-out-inline">Sold Out</span>{%- endunless -%}</h3>
    </a>
    {%- comment -%} Show price only when product price is ₹10,00,000 (10 lacs) or more. product.price is in paise. {%- endcomment -%}
    {%- if product.price <= 100000000 -%}
      <div class="product-card__price">
        {{ product.price | money }}
      </div>
    {%- endif -%}

    {%- if product.price > 100000000 -%}
      <div class="product-card__price">
        Price on request
      </div>
    {%- endif -%}

    <div class="product-card__actions">
      <button
        class="product-card__wishlist-btn"
        aria-label="Add to wishlist"
        data-wishlist-toggle
        data-product-id="{{ product.id }}"
        data-product-title="{{ product.title | escape }}"
        data-product-url="{{ product.url }}"
        data-product-price="{{ product.price | money }}"
        data-product-image="{{ product.featured_image | image_url: width: 600 }}"
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
        onclick="event.preventDefault(); WishlistApp.toggle(this);"
      >
        {% render 'icon', name: 'heart' %}
      </button>
      <a href="{{ product.url }}" class="btn btn--details">VIEW DETAILS</a>
    </div>
  </div>
</div>
