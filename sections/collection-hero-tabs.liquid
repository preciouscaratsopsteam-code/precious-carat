    width: 100%;
    padding: 18px 12px;
    background: transparent;
    border: 1px solid #ccc;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #2c3e50;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
    text-transform: uppercase;
    border-radius: 0;
  }

  .collection-tabs__btn:hover {
    background: #f5f5f5;
  }

  .collection-tabs__btn.is-active {
    color: #fff;
    background: #3B4A2F;
    border-color: #3B4A2F;
  }

  /* ========== Tab Panels ========== */
  .collection-tabs__panels {
    padding: 40px 0 60px;
    background: transparent;
  }

  .collection-tabs__panel {
    display: none;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
    animation: fadeInTab 0.4s ease;
  }

  .collection-tabs__panel.is-active {
    display: block;
  }

  .collection-tabs__panel-title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 20px;
    color: #1a1a1a;
    border: none;
    padding: 0;
  }

  .collection-tabs__panel-content {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    line-height: 1.8;
    color: #444;
  }

  .collection-tabs__panel-content ul {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
  }
  .collection-tabs__panel-content ul li {
    padding: 3px 0;
    font-size: 15px;
    color: #333;
    line-height: 1.7;
  }
  .collection-tabs__panel-content ul li::before {
    content: "•  ";
    color: #333;
    font-weight: 700;
  }

  @keyframes fadeInTab {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ========== Responsive ========== */
  @media screen and (max-width: 992px) {
    .collection-hero__lifestyle {
      min-height: 360px;
    }
    .collection-hero__info {
      padding: 36px 28px;
    }
    .collection-hero__title {
      font-size: 30px;
    }
  }

  @media screen and (max-width: 768px) {
    .collection-hero {
      flex-wrap: wrap;
    }
    .collection-hero__lifestyle {
      flex: 1 1 100%;
      max-width: 100%;
      min-height: 280px;
    }
    .collection-hero__info {
      flex: 1 1 100%;
      max-width: 100%;
      padding: 30px 20px;
    }
    .collection-hero__title {
      font-size: 28px;
    }
    .collection-tabs__list {
      flex-wrap: nowrap;
      overflow-x: auto;
    }
    .collection-tabs__item {
      flex: 0 0 auto;
    }
    .collection-tabs__btn {
      padding: 14px 16px;
      font-size: 11px;
    }
    .collection-tabs__panels {
      padding: 30px 0 40px;
    }
    .cht-breadcrumb__nav {
      font-size: 12px;
    }
  }
</style>

<script>
  (function() {
    function initTabs() {
      const container = document.querySelector('.collection-hero-tabs');
      if (!container) return;

      const buttons = container.querySelectorAll('.collection-tabs__btn');
      const panels = container.querySelectorAll('.collection-tabs__panel');

      buttons.forEach(btn => {
        btn.addEventListener('click', function() {
          const tabId = this.getAttribute('data-tab');
          const isActive = this.classList.contains('is-active');

          // Reset all others
          buttons.forEach(b => {
            b.classList.remove('is-active');
            b.setAttribute('aria-selected', 'false');
          });
          panels.forEach(p => p.classList.remove('is-active'));

          // If it wasn't active, activate it. If it was already active, it stays removed (toggled off).
          if (!isActive) {
            this.classList.add('is-active');
            this.setAttribute('aria-selected', 'true');
            const targetPanel = container.querySelector(`#tab-${tabId}`);
            if (targetPanel) {
              targetPanel.classList.add('is-active');
            }
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs);
    } else {
      initTabs();
    }
  })();
</script>

