{%- comment -%}
  Blog Listing — featured article + grid of article cards
{%- endcomment -%}

<section class="blog-listing section-padding" id="blog-{{ blog.handle }}">
  <div class="page-width">
    <nav class="blog-breadcrumb" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span class="blog-breadcrumb__sep">/</span>
      <span class="blog-breadcrumb__current">{{ blog.title | default: 'Our Blogs' }}</span>
    </nav>

    <header class="blog-listing__header">
      <h1 class="blog-listing__title">{{ section.settings.heading | default: 'Learn How Gems Transform Energy' }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="blog-listing__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- paginate blog.articles by section.settings.posts_per_page -%}
      {%- if blog.articles.size == 0 -%}
        <div class="blog-listing__empty">
          <p>No articles yet. Check back soon for insights on gemstones, astrology, and more.</p>
        </div>
      {%- else -%}
        {%- assign featured = blog.articles.first -%}
        {%- assign featured_words = featured.content | strip_html | split: ' ' | size -%}
        {%- assign featured_read = featured_words | divided_by: 200 | at_least: 1 -%}

        <article class="blog-featured">
          <a class="blog-featured__media" href="{{ featured.url }}">
            {%- if featured.image != blank -%}
              <img
                src="{{ featured.image | image_url: width: 900 }}"
                alt="{{ featured.image.alt | default: featured.title | escape }}"
                loading="lazy"
                width="900"
                height="600"
              >
            {%- else -%}
              <div class="blog-card__placeholder">{{ featured.title | truncate: 20 }}</div>
            {%- endif -%}
          </a>
          <div class="blog-featured__body">
            <div class="blog-card__meta">
              {%- if featured.tags.size > 0 -%}
                <span class="blog-card__badge">{{ featured.tags.first }}</span>
              {%- endif -%}
              <span class="blog-card__date">
                {{ featured.published_at | date: '%d %b %Y' }} | {{ featured_read }} Min Read
              </span>
            </div>
            <h2 class="blog-featured__title">
              <a href="{{ featured.url }}">{{ featured.title }}</a>
            </h2>
            <div class="blog-featured__excerpt">
              {%- if featured.excerpt != blank -%}
                {{ featured.excerpt | strip_html | truncatewords: 60 }}
              {%- else -%}
                {{ featured.content | strip_html | truncatewords: 60 }}
              {%- endif -%}
            </div>
            <a href="{{ featured.url }}" class="blog-card__read-more">Read More <span aria-hidden="true">→</span></a>
          </div>
        </article>

        {%- if blog.articles.size > 1 -%}
          <div class="blog-grid">
            {%- for article in blog.articles offset: 1 -%}
              {%- assign a_words = article.content | strip_html | split: ' ' | size -%}
              {%- assign a_read = a_words | divided_by: 200 | at_least: 1 -%}
              <article class="blog-card">
                <a class="blog-card__media" href="{{ article.url }}">
                  {%- if article.image != blank -%}
                    <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="lazy" width="800" height="533">
                  {%- else -%}
                    <div class="blog-card__placeholder">{{ article.title | truncate: 20 }}</div>
                  {%- endif -%}
                </a>
                <div class="blog-card__body">
                  <div class="blog-card__meta">
                    {%- if article.tags.size > 0 -%}
                      <span class="blog-card__badge">{{ article.tags.first }}</span>
                    {%- endif -%}
                    <span class="blog-card__date">
                      {{ article.published_at | date: '%d %b %Y' }} | {{ a_read }} Min Read
                    </span>
                  </div>
                  <h4 class="blog-card__title">
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </h4>
                  <p class="blog-card__excerpt">
                    {%- if article.excerpt != blank -%}
                      {{ article.excerpt | strip_html | truncatewords: 22 }}
                    {%- else -%}
                      {{ article.content | strip_html | truncatewords: 22 }}
                    {%- endif -%}
                  </p>
                  <a href="{{ article.url }}" class="blog-card__read-more">Read More <span aria-hidden="true">→</span></a>
                </div>
              </article>
            {%- endfor -%}
          </div>

          <div class="blog-listing__actions">
            <a href="{{ blog.url }}" class="btn btn--secondary">VIEW ALL</a>
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <div class="blog-listing__pagination collection-page__pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

<style>
  .blog-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #888;
    font-family: var(--font-body);
    margin-bottom: var(--space-xl);
  }
  .blog-breadcrumb a { color: #888; text-decoration: none; }
  .blog-breadcrumb a:hover { color: var(--color-gold); }
  .blog-breadcrumb__sep { color: #ccc; }
  .blog-breadcrumb__current { color: #282c3f; }

  .blog-listing__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-2xl);
  }
  .blog-listing__title {
    font-family: var(--font-heading);
    font-size: 38px;
    font-weight: 500;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 12px;
    letter-spacing: 0.01em;
  }
  .blog-listing__subheading {
    font-family: var(--font-body);
    font-size: 14px;
    color: #6b6b6b;
    margin: 0;
  }

  .blog-listing__empty {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--color-text-muted, #888);
  }

  /* Featured Article */
  .blog-featured {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: var(--space-2xl);
    padding: var(--space-md);
    border-radius: var(--radius-lg, 8px);
    background: #fff;
  }
  .blog-featured__media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md, 6px);
    aspect-ratio: 3 / 2;
  }
  .blog-featured__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .blog-featured__media:hover img { transform: scale(1.03); }
  .blog-featured__title {
    font-family: var(--font-heading);
    font-size: 26px;
    font-weight: 500;
    margin: 10px 0 14px;
    color: var(--color-primary, #1a2a3a);
    line-height: 1.25;
  }
  .blog-featured__title a { color: inherit; text-decoration: none; }
  .blog-featured__title a:hover { color: var(--color-gold); }
  .blog-featured__excerpt {
    font-family: var(--font-body);
    font-size: 14px;
    color: #555;
    line-height: 1.7;
    margin-bottom: 18px;
  }

  /* Cards grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
    margin-bottom: var(--space-2xl);
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: transparent;
  }
  .blog-card__media {
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 6px;
    background: #faf6ef;
    margin-bottom: 14px;
  }
  .blog-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .blog-card:hover .blog-card__media img { transform: scale(1.03); }
  .blog-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eee6d6;
    color: #b79d66;
    font-family: var(--font-heading);
    font-size: 22px;
  }
  .blog-card__body {
    padding: 0 4px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 11px;
    color: #888;
  }
  .blog-card__badge {
    background: #f2d08a;
    color: #5a3d00;
    padding: 3px 10px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: capitalize;
  }
  .blog-card__date { color: #8a8a8a; font-size: 11px; }
  .blog-card__title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 500;
    margin: 2px 0 4px;
    color: var(--color-primary, #1a2a3a);
    line-height: 1.3;
  }
  .blog-card__title a { color: inherit; text-decoration: none; }
  .blog-card__title a:hover { color: var(--color-gold); }
  .blog-card__excerpt {
    font-family: var(--font-body);
    font-size: 13px;
    color: #555;
    line-height: 1.65;
    margin: 0;
  }
  .blog-card__read-more {
    align-self: flex-start;
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-gold);
    text-decoration: none;
  }
  .blog-card__read-more:hover { color: var(--color-primary, #1a2a3a); }

  .blog-listing__pagination { text-align: center; margin-top: var(--space-xl); }

  @media (max-width: 992px) {
    .blog-featured { grid-template-columns: 1fr; gap: 20px; }
    .blog-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; }
  }
  @media (max-width: 640px) {
    .blog-listing__title { font-size: 28px; }
    .blog-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>

{% schema %}
{
  "name": "Blog Listing",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn How Gems Transform Energy"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Stories, insights, and knowledge from the world of precious gemstones."
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 10,
      "label": "Articles per page"
    }
  ]
}
{% endschema %}
