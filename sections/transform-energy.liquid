{%- comment -%}
  Transform Energy Section
{%- endcomment -%}

<section class="transform-energy section-padding" id="section-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading animate-fadeInUp">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="transform-energy__grid animate-fadeInUp" style="animation-delay: 150ms;">
      {%- assign selected_blog = blogs[section.settings.blog] -%}
      {%- if selected_blog == blank or selected_blog.articles.size == 0 -%}
        {%- assign selected_blog = blogs['news'] -%}
      {%- endif -%}
      {%- if selected_blog == blank or selected_blog.articles.size == 0 -%}
        {%- for b in blogs -%}
          {%- if b.articles.size > 0 -%}
            {%- assign selected_blog = b -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- assign post_limit = section.settings.post_limit | default: 3 -%}
      {%- if selected_blog.articles.size > 0 -%}
        {%- for article in selected_blog.articles limit: post_limit -%}
          {%- assign bg_text = article.tags.first | default: article.title | upcase -%}
          <div class="transform-energy__card">
            <div class="energy-card__image-box">
              <div class="energy-card__bg-text">{{ bg_text }}</div>
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'energy-card__gem', alt: article.title }}
              {%- else -%}
                <div class="energy-card__gem-placeholder"></div>
              {%- endif -%}
              <h3 class="energy-card__main-title">{{ article.title | truncate: 20 }}</h3>
            </div>

            <div class="energy-card__content">
              <h4 class="energy-card__title">{{ article.title }}</h4>
              <p class="energy-card__excerpt">
                {%- if article.excerpt != blank -%}
                  {{ article.excerpt | strip_html | truncatewords: 24 }}
                {%- else -%}
                  {{ article.content | strip_html | truncatewords: 24 }}
                {%- endif -%}
              </p>
              <a href="{{ article.url }}" class="energy-card__link">
                Read More <span>&rarr;</span>
              </a>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p class="transform-energy__empty">No articles found. Select a blog in the section settings.</p>
      {%- endif -%}
    </div>
    
    {%- if section.settings.button_text != blank -%}
      <div class="transform-energy__footer animate-fadeInUp" style="animation-delay: 300ms;">
        <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--secondary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .transform-energy {
    background-color: var(--color-cream-light);
  }
  
  .transform-energy .section-heading {
    text-transform: none;
    font-size: var(--font-size-2xl);
    letter-spacing: 0;
    margin-bottom: var(--space-4xl);
  }

  .transform-energy__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .transform-energy__card {
    background: transparent;
    display: flex;
    flex-direction: column;
  }

  .energy-card__image-box {
    background-color: #fcf9f9;
    padding: var(--space-2xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-lg);
    overflow: hidden;
    min-height: 250px;
    border: 1px solid var(--color-border-light);
  }

  .energy-card__bg-text {
    position: absolute;
    top: 20%;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-heading);
    color: rgba(0,0,0,0.03);
    font-size: 80px;
    white-space: nowrap;
    text-transform: uppercase;
    transform: rotate(-15deg);
    pointer-events: none;
  }

  .energy-card__gem {
    max-width: 120px;
    height: auto;
    position: relative;
    z-index: 2;
    margin-bottom: var(--space-lg);
    filter: drop-shadow(0 15px 25px rgba(0,0,0,0.1));
    transition: transform var(--transition-base);
  }

  .transform-energy__card:hover .energy-card__gem {
    transform: translateY(-5px);
  }

  .energy-card__gem-placeholder {
    width: 100px;
    height: 80px;
    background: #e0d8cc;
    border-radius: 40px;
    position: relative;
    z-index: 2;
    margin-bottom: var(--space-lg);
  }

  .energy-card__main-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    color: #dfcdba; /* pale text */
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 300;
    margin-bottom: 0;
    position: relative;
    z-index: 2;
  }

  .energy-card__content {
    padding: 0 10px;
  }

  .energy-card__title {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .energy-card__excerpt {
    font-size: 11px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .energy-card__link {
    font-size: 11px;
    font-weight: 600;
    text-decoration: underline;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text);
  }

  .energy-card__link:hover {
    color: var(--color-gold);
  }

  .transform-energy__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-4xl);
  }

  @media screen and (max-width: 992px) {
    .transform-energy__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .transform-energy__grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: var(--space-md);
      padding: 0 var(--space-lg) 20px;
      margin: 0 calc(var(--space-lg) * -1);
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
    }

    .transform-energy__grid::-webkit-scrollbar {
      display: none;
    }

    .transform-energy__card {
      flex: 0 0 280px;
      max-width: 85vw;
      scroll-snap-align: start;
    }
  }
</style>

{% schema %}
{
  "name": "Transform Energy",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn How Gems Transform Energy"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Number of posts",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Transform Energy"
    }
  ]
}
{% endschema %}
